{
	"$schema": "https://biomejs.dev/schemas/1.9.0/schema.json",
	"organizeImports": {
		"enabled": true
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true,
			"correctness": {
				"noUnusedImports": "warn",
				"noUnusedVariables": "warn",
				// Dependency arrays are often intentionally narrow on effects
				// that should only run once at mount. Surface as warning so
				// reviewers see it without blocking CI.
				"useExhaustiveDependencies": "warn"
			},
			"a11y": {
				// Cosmetic a11y improvements tracked as a dedicated cleanup
				// issue (#5). Keep them warning-level so CI stays green but
				// the warnings still show up in PR diffs.
				"useButtonType": "warn",
				"noLabelWithoutControl": "warn",
				"noSvgWithoutTitle": "warn",
				"useKeyWithClickEvents": "warn"
			},
			"suspicious": {
				// There are a few genuine `let x;` / `as any` sites in
				// early supervisor / transcript code slated for cleanup.
				// Warn for now; don't let them block unrelated PRs.
				"noImplicitAnyLet": "warn",
				"noExplicitAny": "warn",
				// index-as-key is an anti-pattern but the current call
				// sites are static lists; tracked for cleanup.
				"noArrayIndexKey": "warn"
			},
			"style": {
				"noNonNullAssertion": "warn"
			}
		}
	},
	"formatter": {
		"enabled": true,
		"indentStyle": "tab",
		"lineWidth": 100
	},
	"javascript": {
		"formatter": {
			"quoteStyle": "double",
			"semicolons": "always"
		}
	},
	"files": {
		"ignore": ["node_modules", "dist", "data", ".next"]
	}
}
