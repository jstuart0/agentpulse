# AgentPulse Configuration

# Database: SQLite (default) or PostgreSQL
# Leave empty for SQLite (stored at ./data/agentpulse.db)
# Set to a postgres:// URL for PostgreSQL
DATABASE_URL=

# Server
PORT=3000
HOST=0.0.0.0

# Public URL (used in hook configuration snippets)
PUBLIC_URL=http://localhost:3000

# Initial API key for hook authentication (generated on first run if empty)
AGENTPULSE_INITIAL_API_KEY=

# Log level: debug, info, warn, error
LOG_LEVEL=info
