# AgentPulse Configuration

# Database: SQLite (default) or PostgreSQL
# Leave empty for SQLite (stored at ./data/agentpulse.db)
# Set to a postgres:// URL for PostgreSQL
DATABASE_URL=

# Server
PORT=3000
HOST=0.0.0.0

# Public URL (used in hook configuration snippets)
PUBLIC_URL=http://localhost:3000

# Initial API key for hook authentication (generated on first run if empty)
AGENTPULSE_INITIAL_API_KEY=

# Log level: debug, info, warn, error
LOG_LEVEL=info

# Set to "true" to disable all authentication (API keys + Authentik)
# Useful for local development or trusted networks
DISABLE_AUTH=false

# Anonymous telemetry (opt-out)
# Set to "off" to disable. Respects DO_NOT_TRACK=1.
# See src/server/services/telemetry.ts for what is collected.
AGENTPULSE_TELEMETRY=on
# Optional telemetry classification override: production, self_hosted_real, dev, test, ci
# AGENTPULSE_TELEMETRY_MODE=test
# Or set this for quick local/test deploys so they don't count as real-world installs:
# AGENTPULSE_TELEMETRY_TEST=1
